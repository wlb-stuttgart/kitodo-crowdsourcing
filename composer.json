{
    "name": "wlb/crowdsourcing",
    "description": "Extension for the WLB crowdsourcing digitization project",
    "type": "typo3-cms-extension",
    "license": [
        "GPL-2.0-or-later"
    ],
    "require": {
        "php": "^8.2||~8.4.0",
        "ext-dom": "*",
        "ext-simplexml": "*",
        "typo3/cms-backend": "^13.4",
        "typo3/cms-core": "^13.4",
        "solarium/solarium": "^6.3",
        "galbar/jsonpath": "^3.0",
        "fluidtypo3/vhs": "^7.0",
        "evoweb/sf-register": "^13",
        "evoweb/extender": "^11",
        "sjbr/sr-freecap" : "^13",
        "symfony/filesystem": "^7.3"
    },
    "authors": [
        {
            "name": "effective Webwork GmbH",
            "email": "info@effective-webwork.de",
            "homepage": "https://effective-webwork.de",
            "role": "Developer"
        }
    ],
    "funding": [
        {
            "type": "other",
            "url:": "https://www.wlb-stuttgart.de/"
        }
    ],
    "autoload": {
        "psr-4": {
            "Wlb\\Crowdsourcing\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "crowdsourcing"
        }
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1"
    },
    "config": {
        "allow-plugins": {
            "typo3/cms-composer-installers": true,
            "typo3/class-alias-loader": true
        }
    }
}
